# Copy this file to local.properties and fill in your values.
# local.properties is gitignored and must never be committed.

sdk.dir=/path/to/android-sdk

# Release signing (optional — omit to produce an unsigned APK)
signing.storeFile=/path/to/your/keystore.jks
signing.storePassword=your_store_password
signing.keyAlias=your_key_alias
signing.keyPassword=your_key_password
